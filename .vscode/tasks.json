{
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: g++ build and run",
            "command": "/bin/bash",
            "args": [
                "-c",
                "mkdir -p '${fileDirname}/../../../build' && /usr/bin/g++ -g '${file}' -o '${fileDirname}/../../../build/${fileBasenameNoExtension}' -I/usr/local/include -std=c++17 && echo '--- 실행 결과 ---' && '${fileDirname}/../../../build/${fileBasenameNoExtension}'"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true,
                "clear": true,
                "showReuseMessage": true
            }
        },
        {
            "type": "shell",
            "label": "C/C++: g++ build active file",
            "command": "/bin/bash",
            "args": [
                "-c",
                "mkdir -p '${fileDirname}/../../../build' && /usr/bin/g++ -fdiagnostics-color=always -g '${file}' -o '${fileDirname}/../../../build/${fileBasenameNoExtension}'"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "type": "shell",
            "label": "C/C++: clang++ build active file",
            "command": "/bin/bash",
            "args": [
                "-c",
                "mkdir -p '${fileDirname}/../../../build' && /usr/bin/clang++ -fcolor-diagnostics -fansi-escape-codes -g '${file}' -o '${fileDirname}/../../../build/${fileBasenameNoExtension}'"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++-15 build active file",
            "command": "/opt/homebrew/bin/g++-15",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/../../../build/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}